<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Monitor.Maui.MainPage"
             xmlns:viewmodel="clr-namespace:Monitor.Maui.ViewModel"
             xmlns:models="clr-namespace:Monitor.Core.Models;assembly=Monitor.Core"
             x:DataType="viewmodel:ProcessListViewModel"
             BackgroundColor="#121358" Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,16,20,20" RowSpacing="0">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Monitor"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"/>
                <Label Text="Mac Activity"
                       FontSize="12"
                       TextColor="#9FA8DA"/>
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="↻  Refresh"
                    Command="{Binding LoadProcessesCommand}"
                    BackgroundColor="#232F72"
                    TextColor="#36ADA3"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="36"
                    Padding="16,0"/>
        </Grid>

        <!-- COLUMN HEADERS -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,110,90,100"
              Padding="12,8"
              Margin="0,0,0,6">
            <Label Grid.Column="0" Text="Process" FontSize="11" TextColor="#7986CB" FontAttributes="Bold"/>
            <Label Grid.Column="1" Text="Memory" FontSize="11" TextColor="#7986CB" FontAttributes="Bold" HorizontalOptions="End"/>
            <Label Grid.Column="2" Text="CPU %" FontSize="11" TextColor="#7986CB" FontAttributes="Bold" HorizontalOptions="End"/>
            <Label Grid.Column="3" Text="PID" FontSize="11" TextColor="#7986CB" FontAttributes="Bold" HorizontalOptions="End"/>
        </Grid>

        <!-- PROCESS LIST -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Processes}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ProcessInfo">
                    <Grid ColumnDefinitions="*,110,90,100,90"
                          Padding="12,10"
                          Margin="0,2,0,0"
                          BackgroundColor="#232F72">
                        <Grid.Resources>
                            <Style TargetType="Label">
                                <Setter Property="TextColor" Value="White"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="VerticalOptions" Value="Center"/>
                            </Style>
                        </Grid.Resources>

                        <!-- Name -->
                        <Label Grid.Column="0"
                               Text="{Binding Name}"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"/>

                        <!-- RAM -->
                        <Label Grid.Column="1"
                               Text="{Binding RamMb, StringFormat='{0:F1} MB'}"
                               TextColor="#36ADA3"
                               FontFamily="OpenSansRegular"
                               HorizontalOptions="End"/>

                        <!-- CPU -->
                        <Label Grid.Column="2"
                               Text="{Binding CpuPercent, StringFormat='{0:F1}%'}"
                               TextColor="#9FA8DA"
                               HorizontalOptions="End"/>

                        <!-- PID -->
                        <Label Grid.Column="3"
                               Text="{Binding Id}"
                               TextColor="#7986CB"
                               FontFamily="OpenSansRegular"
                               HorizontalOptions="End"/>

                        <!-- Kill button -->
                        <Button Grid.Column="4"
                                Text="Kill"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ProcessListViewModel}}, Path=KillProcessCommand}"
                                CommandParameter="{Binding Id}"
                                BackgroundColor="#2F578A"
                                TextColor="#EF4444"
                                FontAttributes="Bold"
                                FontSize="12"
                                CornerRadius="6"
                                HeightRequest="30"
                                Padding="8,0"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
